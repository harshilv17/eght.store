# Server
PORT=4000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=eght_db
DB_USER=postgres
DB_PASSWORD=your_password

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# CORS
FRONTEND_URL=http://localhost:3000

# Cloudinary (image hosting). Required only when admin uploads via /api/admin/uploads/sign.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# FX rates per 1 INR. Optional override (JSON). Leave blank for defaults.
# FX_RATES={"USD":0.012,"GBP":0.0095,"AED":0.044}
# FX_UPDATED_AT=2026-05-01T00:00:00.000Z
